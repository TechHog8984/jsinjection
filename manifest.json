{
    "author": "techhog",
    "description": "JavaScript injection",
    "manifest_version": 2,
    "version": "0.1",
    "name": "jsinjection",

    "background": {
        "scripts": ["jsinjection_build.js"]
    },

    "browser_action": {
        "default_title": "jsinjection",
        "default_popup": "popup.html"
    },

    "browser_specific_settings": {
      "gecko": {
        "id": "@techhog-jsinjection",
        "strict_min_version": "58.0"
      }
    },

    "permissions": [
        "scripting",
        "webRequest",
        "webRequestBlocking",
        "tabs",
        "storage",
        "*://*/*"
    ]
}
